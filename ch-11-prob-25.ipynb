    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "period = 3\n",
    "t = np.linspace(-1, 5)\n",
    "\n",
    "f = np.where(t % period < 1, -4,\n",
    "             np.where(t % period < 2, 0, 4))\n",
    "\n",
    "plt.plot(t,f)"

   "source": [
    "import sympy as sp\n",
    "from power import piecewise_rms\n",
    "\n",
    "period = 25\n",
    "t = sp.Symbol('t')\n",
    "functions = [t, t - 5, t - 10, t - 15, t - 20]\n",
    "ranges = [(0, 5), (5, 10), (10, 15), (15, 20), (20, 25)]\n",
    "\n",
    "i_rms = piecewise_rms(functions, ranges, period, t)\n",
    "print(\"i (rms) = \", i_rms)"
   ],

    "import numpy as np\n",
    "\n",
    "q = 140 * 10**3 # kVAR\n",
    "pf = 0.85\n",
    "v_rms = 110 # V (RMS)\n",
    "f = 60 # Hz\n",
    "\n",
    "pf_prime = 0\n",
    "qf_prime = 0\n",
    "\n",
    "C = q / (2 * np.pi * f * v_rms ** 2)\n",
    "print(\"Capacitance: \", C, \" F\")"
